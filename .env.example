# Copy this file to `.env` and fill in your values.
# `.env` is gitignored and is loaded automatically by bin/play.
#
# Shell-set variables always win over .env entries — if both are present,
# the shell wins.
#
# CLI flags (--model, --grunt-model, --nuance-model, --log-level,
# --snapshot-dir) override the env vars below.

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
# Which LLM provider to talk to.
#   anthropic     — Anthropic Claude (cloud). Default. Requires ANTHROPIC_API_KEY.
#   openai-compat — any server speaking /v1/chat/completions (llama.cpp's
#                   llama-server, vLLM, Ollama's openai-compat shim, OpenAI proper).
# HARNESS_BACKEND=anthropic

# ---------------------------------------------------------------------------
# Anthropic credentials (required when HARNESS_BACKEND=anthropic)
# ---------------------------------------------------------------------------
# Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Model selection
# ---------------------------------------------------------------------------
# Two valid configurations:
#   (a) HARNESS_MODEL alone     — same model for both grunt and nuance tiers.
#   (b) HARNESS_GRUNT_MODEL  +  HARNESS_NUANCE_MODEL  — explicit two-tier setup.
# Half-config (only one of grunt/nuance set) aborts at startup.
#
# Built-in default if nothing is set: claude-sonnet-4-6 for both tiers.
# HARNESS_MODEL=claude-sonnet-4-6
# HARNESS_GRUNT_MODEL=claude-haiku-4-5-20251001
# HARNESS_NUANCE_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# OpenAI-compatible backend (only used when HARNESS_BACKEND=openai-compat)
# ---------------------------------------------------------------------------
# Base URL of the local / hosted OpenAI-compatible endpoint.
# Default targets llama.cpp's llama-server on its default port.
# HARNESS_OPENAI_BASE_URL=http://127.0.0.1:8080/v1

# API key for the OpenAI-compatible endpoint. Most local servers ignore this
# field entirely; set it for hosted endpoints (OpenAI proper, routed gateways).
# HARNESS_OPENAI_API_KEY=local

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Levels: debug | info | warn | error. Default: warn.
# debug enables per-call LLM timing (visible via /debug elapsed).
# HARNESS_LOG_LEVEL=warn

# ---------------------------------------------------------------------------
# Snapshots (debugging / save-scumming)
# ---------------------------------------------------------------------------
# If set, the SQLite save file is copied into this directory after every turn.
# Useful for inspecting state evolution or rolling back to a known turn.
# HARNESS_SNAPSHOT_DIR=tmp/snapshots
