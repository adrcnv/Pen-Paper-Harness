#!/usr/bin/env ruby
# Reader for shadow-planner logs (live shadow_planner.jsonl and/or batch
# shadow_replay.jsonl). Model-centric: groups planner stats BY MODEL, so a
# log that mixes runs from different models (e.g. the doesn't-fit-VRAM
# baseline plus a later fits-in-VRAM run appended to the same file) reads
# cleanly, and the same input planned by two models gets diffed.
#
#   bin/shadow_report                          # log/shadow_planner.jsonl
#   bin/shadow_report a.jsonl b.jsonl ...      # combine multiple logs/passes
#
# Per-model: parse-fail %, plan-length distribution, avg latency, empty/4+ flags.
# Cross-model: for inputs planned by 2+ models, how often the runner sequences
# match — the local jackpot signal ("does a fits-in-VRAM model plan like the
# doesn't-fit one"). Plus an aggregate agentic baseline (what the live loop /
# corpus actually did) for plan-vs-actual context.
#
# No Rails boot; pure stdlib. Read-only.

require "json"

paths = ARGV.empty? ? [ File.expand_path("../log/shadow_planner.jsonl", __dir__) ] : ARGV
missing = paths.reject { |p| File.exist?(p) }
abort "No log(s): #{missing.join(', ')}" unless missing.empty?

records = paths.flat_map { |p|
  File.readlines(p).filter_map do |line|
    line = line.strip
    next if line.empty?
    begin
      JSON.parse(line)
    rescue JSON::ParserError
      warn "skipping malformed line in #{p}"
      nil
    end
  end
}
abort "No records." if records.empty?

def runner_seq(plan)
  return "(parse-fail)" if plan.nil?
  return "[]" if plan.empty?
  plan.map { |s| s["invalid"] ? "#{s['runner']}?!" : s["runner"] }.join(" → ")
end

def trunc(str, n)
  s = str.to_s.gsub(/\s+/, " ").strip
  s.length > n ? "#{s[0, n - 1]}…" : s
end

# Flatten to per-(model, input) plan entries across all records/tiers.
plan_entries = []   # {model, input, plan, parse_error, ms}
records.each do |r|
  (r["planner"] || {}).each_value do |p|
    plan_entries << {
      model:       p["model"] || "(unknown)",
      input:       r["input"],
      plan:        p["plan"],
      parse_error: p["parse_error"],
      ms:          p["duration_ms"]
    }
  end
end
models = plan_entries.map { |e| e[:model] }.uniq

puts "═" * 100
puts "Shadow report — #{records.size} turns — #{paths.size} log(s) — models: #{models.join(', ')}"
puts "═" * 100

records.each do |r|
  puts
  puts "Turn #{r['turn'] || '?'}  │  #{trunc(r['input'], 80)}"
  (r["planner"] || {}).each do |tier, p|
    ms = p["duration_ms"] ? "#{p['duration_ms']}ms" : "—"
    tag = p["model"] ? "#{tier}/#{p['model']}" : tier
    puts "  plan[#{tag}] (#{ms}): #{runner_seq(p['plan'])}"
    puts "    ⚠ #{trunc(p['parse_error'], 80)}" if p["parse_error"]
  end
  ag = r["agentic"] || {}
  unless ag.empty?
    shape = ag["silent"] ? "SILENT" : (ag["tool_sequence"] || []).join(" → ")
    flag = ag["tool_count"].to_i >= 10 ? "  ⟵ RUNAWAY" : ""
    puts "  agentic (#{ag['tool_count']} calls): #{trunc(shape, 90)}#{flag}"
  end
end

# ── Per-model planner summary ────────────────────────────────────────────────
puts
puts "═" * 100
puts "PLANNER — by model"
puts "═" * 100
models.each do |m|
  es = plan_entries.select { |e| e[:model] == m }
  parsed = es.reject { |e| e[:plan].nil? }
  fail_n = es.size - parsed.size
  lengths = parsed.map { |e| e[:plan].size }
  dist = lengths.tally.sort.map { |len, c| "#{len}:#{c}" }.join(" ")
  empty_n = lengths.count(0)
  overlong = lengths.count { |l| l >= 4 }   # prompt says >4 should've been agentic
  durs = es.filter_map { |e| e[:ms] }
  avg = durs.empty? ? "—" : "#{durs.sum / durs.size}ms"
  puts
  puts "#{m}  (#{es.size} inputs)"
  puts "  parse failures:    #{fail_n}  (#{es.empty? ? 0 : (100.0 * fail_n / es.size).round}%)"
  puts "  plan lengths:      #{dist.empty? ? '(none)' : dist}   (len:count)"
  puts "  empty plans:       #{empty_n}"
  puts "  plans of 4+ steps: #{overlong}   (suspect — prompt says use one 'agentic' step instead)"
  puts "  avg latency:       #{avg}"
end

# ── Cross-model agreement on shared inputs ───────────────────────────────────
if models.size >= 2
  by_input = Hash.new { |h, k| h[k] = {} }
  plan_entries.each do |e|
    next if e[:plan].nil?
    by_input[e[:input]][e[:model]] = e[:plan].map { |s| s["runner"] }
  end
  shared = by_input.select { |_, mp| mp.size >= 2 }

  puts
  puts "═" * 100
  puts "CROSS-MODEL AGREEMENT (inputs planned by 2+ models)"
  puts "═" * 100
  if shared.empty?
    puts "  No inputs were planned by more than one model — run the same inputs"
    puts "  (e.g. the corpus via bin/shadow_replay) through each model to compare."
  else
    agree = 0
    shared.each do |input, mp|
      seqs = mp.values.map { |s| s.join("→") }.uniq
      ok = seqs.size == 1
      agree += 1 if ok
      mark = ok ? "✓" : "✗"
      puts "  #{mark} #{trunc(input, 60)}"
      mp.each { |model, s| puts "      #{model}: #{s.join(' → ')}" } unless ok
    end
    puts
    puts "  identical runner sequence: #{agree}/#{shared.size}  (#{(100.0 * agree / shared.size).round}%)"
  end
end

# ── Aggregate agentic baseline ───────────────────────────────────────────────
ag_records = records.map { |r| r["agentic"] }.reject { |a| a.nil? || a.empty? }
unless ag_records.empty?
  n = ag_records.size
  silent  = ag_records.count { |a| a["silent"] }
  runaway = ag_records.count { |a| a["tool_count"].to_i >= 10 }
  puts
  puts "═" * 100
  puts "AGENTIC baseline (what the live loop / corpus actually did, #{n} turns)"
  puts "═" * 100
  puts "  silent turns (0 tools):    #{silent}  (#{(100.0 * silent / n).round}%)"
  puts "  runaway turns (≥10 tools): #{runaway}  (#{(100.0 * runaway / n).round}%)"
end
